# Server
PORT=5000
NODE_ENV=production

# Database (required on Vercel — add in Project → Settings → Environment Variables)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/future-it-college

# Client — comma-separate multiple origins for production (Vercel frontend URL)
CLIENT_URL=http://localhost:5173,https://your-frontend.vercel.app

# JWT (required in production)
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Email (Nodemailer) - used for admission/contact notification emails
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_TO=DCM20020@gmail.com

# Cloudinary (required on Vercel for profile/image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Seed defaults (used only by npm run seed:exam — run locally, not on Vercel)
SEED_ADMIN_EMAIL=admin@futureitcollege.com
SEED_ADMIN_PASSWORD=Admin@123
